# Auto detect text files and perform LF normalization
* text=auto

# Force LF line endings for text files
*.md text eol=lf
*.txt text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.py text eol=lf
*.html text eol=lf
*.css text eol=lf
*.xml text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.zip binary
*.exe binary
*.whl binary
*.dll binary

# Scripts should use LF
*.sh text eol=lf
*.bat text eol=crlf
*.ps1 text eol=crlf

