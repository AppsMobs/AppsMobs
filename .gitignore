# Exclure TOUT sauf les fichiers essentiels listés ci-dessous

# Tout le code source
core/
ui/
electron-app/
license_server/
website/
dashboard/
discord-bot/

# Fichiers Python
*.py
*.pyc
*.pyo
*.pyd
__pycache__/
*.so
*.egg
*.egg-info/
venv/
env/
.venv/

# Fichiers de build et distribution
build/
dist/
*.exe
*.msi
*.dmg
*.pkg
*.spec
*.whl
releases/

# Fichiers de configuration et secrets
config.json
config.ini
*.env
.env*
secrets.json
credentials.json

# Node.js
node_modules/
package-lock.json

# Fichiers de développement
*.bat
*.ps1
*.sh
*.txt
*.log
*.tmp
*.bak
